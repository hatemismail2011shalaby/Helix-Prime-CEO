services:
  - name: helix-ceo-ai-assistant
    type: web
    env: docker
    dockerfilePath: ./Dockerfile
    dockerContext: .
    plan: starter
    healthCheckPath: /health
    envVars:
      - key: HELIX_MODEL_BACKEND
        value: cloud
      - key: GROQ_API_KEY
        sync: false
      - key: GROQ_MODEL
        value: llama-3.3-70b-versatile
      - key: HELIX_AGENT_TIMEOUT
        value: "180"